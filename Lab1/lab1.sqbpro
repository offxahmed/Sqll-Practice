="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="41"/><column index="2" value="112"/><column index="3" value="96"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">INSERT INTO emp(empno,ename,job,mgr,hiredate,sal,comm,deptno) VALUES(4375,&quot;Badshah&quot;,&quot;chairperson&quot;,323,2001-03-09,120000,NULL,20),
(5223,&quot;Abdullah&quot;,&quot;saleperson&quot;,NULL,2001-03-09,120000,NULL,20)
</sql><sql name="SQL 2*">UPDATE emp 
SET mgr = 435
WHERE ename = &quot;Badshah&quot; AND mgr = &quot;NULL&quot;
</sql><sql name="SQL 4*">UPDATE emp
SET comm = 4008.33
WHERE job = &quot;saleperson&quot; </sql><sql name="SQL 5*">UPDATE emp
SET comm = 4678.33
WHERE job = &quot;clerk&quot; </sql><sql name="SQL 6*">UPDATE emp
SET comm = 400458.33
WHERE job = &quot;chairperson&quot; </sql><sql name="SQL 7*">CREATE TABLE dept
(
	deptno INTEGER,
	dname TEXT,
	location TEXT
)</sql><sql name="SQL 8*">INSERT INTO dept(deptno,dname,location)
VALUES(10,&quot;Accounting&quot;,&quot;Sarghoda&quot;),
(20,&quot;Research&quot;,&quot;Multan&quot;),
(30,&quot;Sales&quot;,&quot;Gujranwala&quot;),
(40,&quot;Operations&quot;,&quot;Lahore&quot;)</sql><sql name="SQL 9*">SELECT *FROM salgrade ORDER by &quot;grade&quot;</sql><sql name="SQL 10*">SELECT ename, sal, sal+comm FROM emp WHERE comm &gt;0</sql><sql name="SQL 11*">SELECT ename,empno,hiredate,sal FROM emp WHERE deptno = &quot;10&quot;</sql><sql name="SQL 12*">DELETE FROM emp WHERE job = &quot;clerk&quot;</sql><current_tab id="10"/></tab_sql></sqlb_project>
